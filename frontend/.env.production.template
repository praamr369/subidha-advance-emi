# Copy this file to frontend/.env.production on the deployment target only.
# Do not put backend secrets into any NEXT_PUBLIC_* variable.

# Canonical value includes `/api/v1`. The frontend also tolerates:
# - `https://api.example.com` (it will append `/api/v1`)
# - `https://app.example.com/api` (it will normalize to `/api/v1`)
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
NEXT_PUBLIC_APP_NAME=SUBIDHA CORE
