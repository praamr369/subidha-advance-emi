# Copy to frontend/.env.production on deployment host only.
# Never store backend secrets in NEXT_PUBLIC_* variables.

# Canonical API base includes `/api/v1`.
# Normalizer also accepts:
# - https://api.example.com
# - https://api.example.com/api
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
NEXT_PUBLIC_ADMIN_APP_URL=http://127.0.0.1:5173
NEXT_PUBLIC_APP_NAME=SUBIDHA CORE
NODE_ENV=production
