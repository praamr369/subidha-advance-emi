# SUBIDHA CORE — NEXT.JS FRONTEND PRODUCTION ENV TEMPLATE
# Server/runtime file: /etc/subidha-core/frontend.env OR hosting panel
# Git template path: frontend/.env.production.template
# DO NOT PUT PRIVATE SECRETS IN NEXT_PUBLIC_* VALUES.

NEXT_PUBLIC_APP_NAME=Subidha Furniture
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_API_BASE_URL=__FILL_PUBLIC_API_BASE_URL__
NEXT_PUBLIC_SITE_URL=__FILL_PUBLIC_FRONTEND_URL__
NEXT_PUBLIC_SUPPORT_PHONE=__FILL_BUSINESS_PHONE__
NEXT_PUBLIC_SUPPORT_EMAIL=__FILL_PUBLIC_SUPPORT_EMAIL__
NEXT_PUBLIC_BUSINESS_CITY=Asansol
NEXT_PUBLIC_BUSINESS_STATE=West Bengal

# Business-mode display flags only. These are not security controls.
NEXT_PUBLIC_GST_STATUS=UNREGISTERED
NEXT_PUBLIC_SHOW_GST_BREAKUP=false
NEXT_PUBLIC_ALLOW_TAX_INVOICE_DOWNLOAD=false
NEXT_PUBLIC_LUCKY_PLAN_PUBLIC_WORDING=Monthly Waiver Benefit
NEXT_PUBLIC_LUCKY_PLAN_EXTERNAL_LOTTERY_LINKED=false
NEXT_PUBLIC_PARTNER_RECEIPT_REQUEST_ONLY=true
NEXT_PUBLIC_KYC_MASKED_DOCUMENTS_ONLY=true
NEXT_PUBLIC_FINANCE_FACILITATION_ONLY=true

# Optional analytics/monitoring public keys only. Leave blank unless configured.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_ID=
