{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp-dashboard-tests",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "lib": ["es2022"],
    "types": ["node"],
    "jsx": "react-jsx",
    "declaration": false,
    "sourceMap": false,
    "incremental": false
  },
  "include": [
    "tests/unit/dashboard-widget-board.test.ts",
    "tests/unit/dashboard-preset-catalogs.test.ts",
    "tests/unit/non-gst-compliance-ui.test.ts",
    "src/lib/dashboard-widget-board.ts"
  ],
  "exclude": ["node_modules"]
}
