{
  "name": "subidha-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-next-build.mjs",
    "build:smoke": "node scripts/run-next-build.mjs --smoke",
    "start": "next start",
    "start:smoke": "next start --hostname 127.0.0.1 --port 3100",
    "lint": "node scripts/run-eslint.mjs",
    "check:routes": "node scripts/check-routes.mjs",
    "check:public-release": "node scripts/check-public-release-readiness.mjs",
    "inventory:routes": "node scripts/generate-route-inventory.mjs",
    "typecheck": "node scripts/run-typecheck.mjs",
    "validate": "npm run check:routes && npm run lint && npm run typecheck && npm run test:dashboard-presets && npm run build",
    "test:e2e:smoke": "npm run build:smoke && playwright test --project=chromium-smoke",
    "test:e2e:release-smoke": "npm run build:smoke && playwright test --project=chromium-release-smoke",
    "test:e2e:smoke:headed": "npm run build:smoke && playwright test --project=chromium-smoke --headed",
    "test:e2e:auth-smoke": "playwright test --project=chromium-auth-smoke",
    "test:e2e:auth-smoke:headed": "playwright test --project=chromium-auth-smoke --headed",
    "test:e2e:accounting-visual": "playwright test --project=chromium-smoke tests/e2e/accounting_setup_visual_reference.spec.ts",
    "docs:accounting-visual": "node scripts/build-accounting-visual-reference.mjs",
    "test:e2e:install": "playwright install chromium",
    "playwright:install": "playwright install chromium",
    "playwright:check": "node scripts/check-playwright-env.mjs",
    "test:dashboard-presets": "node scripts/run-dashboard-widget-board-tests.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^2.1.9",
    "tailwind-merge": "^3.5.0"
  },
  "overrides": {
    "postcss": "8.5.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
