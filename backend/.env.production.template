# SUBIDHA CORE — BACKEND PRODUCTION ENV TEMPLATE
# Real file location on server: /etc/subidha-core/backend.env
# Git template path: backend/.env.production.template
# DO NOT COMMIT REAL VALUES.

# ---------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------
DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=__FILL_GENERATED_DJANGO_SECRET_KEY__
DJANGO_ALLOWED_HOSTS=__FILL_DOMAIN_LIST_COMMA_SEPARATED__

# Example:
# DJANGO_ALLOWED_HOSTS=subidhafurnitureasansol.com,www.subidhafurnitureasansol.com,api.subidhafurnitureasansol.com,127.0.0.1,localhost

# ---------------------------------------------------------------------
# HTTPS / browser security
# ---------------------------------------------------------------------
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
CSRF_TRUSTED_ORIGINS=__FILL_HTTPS_ORIGINS_COMMA_SEPARATED__
CORS_ALLOWED_ORIGINS=__FILL_FRONTEND_ORIGINS_COMMA_SEPARATED__

# ---------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------
DATABASE_URL=postgres://__FILL_DB_USER__:__FILL_DB_PASSWORD__@__FILL_DB_HOST__:__FILL_DB_PORT__/__FILL_DB_NAME__
POSTGRES_DB=__FILL_DB_NAME__
POSTGRES_USER=__FILL_DB_USER__
POSTGRES_PASSWORD=__FILL_DB_PASSWORD__
POSTGRES_HOST=__FILL_DB_HOST__
POSTGRES_PORT=5432

# ---------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# ---------------------------------------------------------------------
# JWT / auth
# ---------------------------------------------------------------------
JWT_SIGNING_KEY=__FILL_GENERATED_JWT_SIGNING_KEY__
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------
# Email / OTP
# Use Gmail app password, not normal Gmail password.
# ---------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=__FILL_BUSINESS_GMAIL_ADDRESS__
EMAIL_HOST_PASSWORD=__FILL_GMAIL_APP_PASSWORD__
DEFAULT_FROM_EMAIL=Subidha Furniture <__FILL_BUSINESS_GMAIL_ADDRESS__>
OTP_EMAIL_ENABLED=true

# ---------------------------------------------------------------------
# Business profile / legal status
# Current rule: business may start GST-unregistered.
# In UNREGISTERED mode backend must block GST collection, tax invoice, ITC wording, and GST credit note.
# ---------------------------------------------------------------------
BUSINESS_LEGAL_NAME=__FILL_LEGAL_ENTITY_NAME__
BUSINESS_TRADE_NAME=Subidha Furniture
BUSINESS_OWNER_NAME=__FILL_OWNER_NAME__
BUSINESS_PHONE=__FILL_BUSINESS_PHONE__
BUSINESS_EMAIL=__FILL_BUSINESS_EMAIL__
BUSINESS_ADDRESS_LINE1=__FILL_ADDRESS_LINE1__
BUSINESS_ADDRESS_LINE2=__FILL_ADDRESS_LINE2__
BUSINESS_CITY=Asansol
BUSINESS_DISTRICT=Paschim Bardhaman
BUSINESS_STATE=West Bengal
BUSINESS_PINCODE=__FILL_PINCODE__
BUSINESS_UDYAM_NO=__FILL_UDYAM_NUMBER_OPTIONAL__

# ---------------------------------------------------------------------
# GST status
# ---------------------------------------------------------------------
GST_STATUS=UNREGISTERED
GSTIN=
GST_EFFECTIVE_DATE=
GST_SCHEME=
GST_UNREGISTERED_BILLING_MODE=true
GST_TURNOVER_WARNING_1=1000000
GST_TURNOVER_WARNING_2=1500000
GST_TURNOVER_PREPARE=1800000
GST_CONSERVATIVE_TRIGGER=2000000

# ---------------------------------------------------------------------
# Lucky Plan legal classification
# ---------------------------------------------------------------------
LUCKY_PLAN_EXTERNAL_LOTTERY_LINKED=false
LUCKY_PLAN_SELECTION_METHOD=HASH_FAIRNESS
LUCKY_PLAN_BENEFIT_TYPE=CONTRACTUAL_WAIVER
LUCKY_PLAN_FUNDING_SOURCE=COMPANY_PROMOTIONAL_DISCOUNT
LUCKY_PLAN_CUSTOMER_POOL_FLAG=false
LUCKY_PLAN_PUBLIC_WORDING=Monthly Waiver Benefit
LUCKY_PLAN_BACKEND_WORDING=waiver_recipient
LUCKY_PLAN_MARKETING_WINNER_ALLOWED=true
LUCKY_PLAN_PUBLIC_LAUNCH_STATUS=ADVOCATE_CA_REVIEW_REQUIRED

# ---------------------------------------------------------------------
# Waiver / refund / late-payment control
# ---------------------------------------------------------------------
ALLOW_GST_CREDIT_NOTE_FOR_WAIVER=false
WAIVER_REQUIRES_CA_MODE=true
WAIVER_REQUIRES_ELIGIBILITY_SNAPSHOT=true
WAIVER_REQUIRES_HASH_COMMIT_REVEAL=true
REFUND_SLA_WORKING_DAYS=7
LUCKY_PLAN_FULL_REFUND_ON_CANCEL=true
LATE_PAYMENT_CHARGE_ENABLED=true
LATE_PAYMENT_WORDING=Late Payment Charge
LATE_PAYMENT_WAIVER_INELIGIBILITY_ENABLED=true

# ---------------------------------------------------------------------
# Partner receipt controls
# ---------------------------------------------------------------------
PARTNER_RECEIPT_ADMIN_APPROVAL_REQUIRED=true
PARTNER_CAN_CREATE_FINAL_RECEIPT=false
PARTNER_CAN_COLLECT_CASH_ONLY_IF_APPROVED=false

# ---------------------------------------------------------------------
# KYC / document privacy
# ---------------------------------------------------------------------
KYC_DOCUMENT_ENCRYPTION_KEY=__FILL_GENERATED_FERNET_KEY__
KYC_MASKING_REQUIRED=true
KYC_STORE_FULL_AADHAAR=false
KYC_STORE_FULL_PAN=false
KYC_DOCUMENT_ACCESS_AUDIT_REQUIRED=true
PRIVATE_DOCUMENT_ROOT=/var/lib/subidha-core/private-documents

# ---------------------------------------------------------------------
# Storage / media
# ---------------------------------------------------------------------
MEDIA_ROOT=/var/lib/subidha-core/media
STATIC_ROOT=/var/lib/subidha-core/static

# ---------------------------------------------------------------------
# Backups
# ---------------------------------------------------------------------
BACKUP_ENCRYPTION_KEY=__FILL_GENERATED_BACKUP_KEY__
BACKUP_DIR=/var/backups/subidha-core

# ---------------------------------------------------------------------
# Optional observability
# ---------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO

# ---------------------------------------------------------------------
# Disabled until legally/operationally approved
# ---------------------------------------------------------------------
SMS_PROVIDER_ENABLED=false
WHATSAPP_PROVIDER_ENABLED=false
PAYMENT_GATEWAY_ENABLED=false
BNPL_ENABLED=false
THIRD_PARTY_LENDER_INTEGRATION_ENABLED=false
