# Backend environment example for local development and deployment
# Copy this file to backend/.env and replace placeholder values.
# Do not commit your real backend/.env file.

DJANGO_ENV=development
DJANGO_DEBUG=true
# Leave blank in local development to use the built-in local-only fallback.
# In production set a random 50+ character secret from your secret manager.
DJANGO_SECRET_KEY=
# Optional but recommended in production: separate 32+ character HMAC key for JWT signing.
# JWT_SIGNING_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# Preferred deployment path: provide a full PostgreSQL URL.
# Example format only:
# DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME

# Alternative explicit PostgreSQL fields.
# Use these if you do not want to provide DATABASE_URL.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=DBNAME
# DB_USER=USER
# DB_PASSWORD=PASS
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_CONN_MAX_AGE=60

# Deployment and proxy/security settings
# TRUST_X_FORWARDED_PROTO=true
# USE_X_FORWARDED_HOST=true
# SECURE_SSL_REDIRECT=true
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=Lax
# CSRF_COOKIE_SAMESITE=Lax
# DJANGO_LOG_LEVEL=INFO
# STATIC_ROOT=/app/staticfiles
# MEDIA_ROOT=/app/media

# Operational health settings
# HEALTHCHECK_DB_ALIAS=default
# HEALTHCHECK_CHECK_MIGRATIONS=true
# HEALTHCHECK_INCLUDE_DETAILS=false

# OTP delivery and password reset settings
# Current code supports:
# - EMAIL delivery via Django send_mail (production-ready, no paid provider needed)
# - CONSOLE logging in local/debug environments
# SMS delivery is still a placeholder and is not production-ready.
#
# Simplest way to enable email OTP (overrides OTP_DELIVERY_BACKEND):
# OTP_EMAIL_ENABLED=true
#
# Fine-grained backend control (ignored when OTP_EMAIL_ENABLED=true):
# OTP_DELIVERY_BACKEND=email   # options: auto | email | sms | sms_email | console
# OTP_ALLOW_EMAIL_FALLBACK=true
# PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
# PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
# PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
# PASSWORD_RESET_MAX_RESENDS=3

# Email transport for OTP fallback
# In local development the default EMAIL_BACKEND is the Django console backend.
# In production set a real mail transport and a customer-facing from address.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_HOST_USER=mailer@example.com
# EMAIL_HOST_PASSWORD=REPLACE_MAIL_PASSWORD
# DEFAULT_FROM_EMAIL=SUBIDHA CORE <no-reply@example.com>
